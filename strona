<script>
function switchTab(name) {
  document.querySelectorAll('.ek-section').forEach(s => s.classList.remove('visible'));
  document.querySelectorAll('.ek-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('visible');
  const tabs = ['home','oferta','ceny','onas','kontakt'];
  const idx = tabs.indexOf(name);
  document.querySelectorAll('.ek-tab')[idx].classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}
</script>

